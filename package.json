{
  "name": "@survata/gha.repo-tagger",
  "version": "1.0.0",
  "main": "./dist/index.js",
  "author": "Christopher Baldwin <cbaldwin@upave.com>",
  "license": "MIT",
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "bin": "./dist/index.js",
  "dependencies": {
    "@actions/core": "^1.11.1"
  },
  "devDependencies": {
    "@types/jest": "^29.2.0",
    "@types/node": "^18.11.3",
    "@typescript-eslint/eslint-plugin": "^5.27.0",
    "@typescript-eslint/parser": "^5.27.0",
    "@vercel/ncc": "^0.38.4",
    "eslint": "^8.16.0",
    "eslint-config-prettier": "^8.5.0",
    "jest": "^29.2.1",
    "prettier": "^2.6.2",
    "ts-jest": "^29.0.3",
    "typescript": "^4.6.4"
  },
  "resolutions": {
    "json5": "^2.2.3",
    "braces": "^3.0.3",
    "minimatch": "^3.1.5",
    "flatted": "^3.4.2",
    "picomatch": "^2.3.2",
    "js-yaml": "^4.2.0",
    "@babel/core": "^7.29.6",
    "@babel/traverse": "^7.29.6"
  },
  "scripts": {
    "build": "tsc",
    "format": "prettier --write \"src/**/*.ts\"",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "tsc && jest --config jestconfig.json",
    "local": "tsc && node ./dist/index.js",
    "package": "tsc && ncc build ./dist/index.js -o bin --target es2022"
  }
}
